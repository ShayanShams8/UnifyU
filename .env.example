# Database
POSTGRES_USER=unifyu
POSTGRES_PASSWORD=unifyu_secret
POSTGRES_DB=unifyu_db
DATABASE_URL=postgresql://unifyu:unifyu_secret@db:5432/unifyu_db

# JWT
SECRET_KEY=change_this_to_a_long_random_secret_key_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Anthropic AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Reddit (public API, no key needed)
REDDIT_USER_AGENT=UnifyU/1.0

# Exchange Rate (free tier)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# Posts storage path (inside container)
POSTS_DIR=/app/posts_content

# CORS
FRONTEND_URL=http://localhost:8081
